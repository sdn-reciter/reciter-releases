# Скопируйте в .env рядом с docker-compose.yml и поправьте под себя.

# Ключ API. Пусто = без авторизации (только для изолированной локальной сети!).
CHATTERBOX_API_KEY=

# Устройство: auto (GPU при наличии) | cuda | cpu.
CHATTERBOX_DEVICE=auto

# Язык синтеза (Chatterbox Multilingual поддерживает 23 языка).
CHATTERBOX_LANG=ru

# Голос по умолчанию: имя wav из ./voices (без расширения). Пусто → встроенный
# голос модели (референс НЕ обязателен, в отличие от F5/CosyVoice).
CHATTERBOX_DEFAULT_SPEAKER=

# Экспрессия (0.25–1.0; 0.5 — нейтрально) и сила следования тексту (0.3–0.7).
CB_EXAGGERATION=0.5
CB_CFG_WEIGHT=0.5

# Ударения RUAccent для /accent (серверный режим ударений в приложении).
USE_RUACCENT=1

# Формат ответа /accent: mark (U+0301) | plus | strip.
CB_STRESS_MODE=mark

# Что скармливать МОДЕЛИ: mark (U+0301 — формат, на котором Chatterbox обучен;
# ударения ставит свой RUAccent) | plus | strip (без ударений).
CB_SYNTH_STRESS=mark

# Биндинг порта: 0.0.0.0 — вся локальная сеть; 127.0.0.1 — только localhost.
CHATTERBOX_BIND=0.0.0.0

# Предохранитель от гигантских запросов.
MAX_TEXT_CHARS=5000
