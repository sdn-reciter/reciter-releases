# Скопируйте в .env рядом с docker-compose.yml и поправьте под себя.

# Ключ API. Пусто = без авторизации (только для изолированной локальной сети!).
ESPEECH_API_KEY=

# Модель (русские файнтюны F5-TTS, Apache 2.0):
#   ESpeech/ESpeech-TTS-1_RL-V2  — по умолчанию (RL-доученная, лучший русский)
#   ESpeech/ESpeech-TTS-1_podcaster — «подкастерская» подача
# Смена модели = пересборка (веса запекаются в образ): docker compose build.
ESPEECH_MODEL=ESpeech/ESpeech-TTS-1_RL-V2

# Устройство: auto (GPU при наличии) | cuda | cpu.
ESPEECH_DEVICE=auto

# Голос по умолчанию: имя wav из ./voices (без расширения). Пусто → первый.
# ВАЖНО: F5/ESpeech требует референс ВСЕГДА — каталог voices не может быть пуст.
ESPEECH_DEFAULT_SPEAKER=

# Ударения RUAccent для /accent (серверный режим ударений в приложении).
USE_RUACCENT=1

# Шаги ODE-солвера: 16 быстрее, 32 качественнее.
ESPEECH_NFE=32

# Guidance и базовая скорость речи.
ESPEECH_CFG=2.0
ESPEECH_SPEED=1.0

# Формат ответа /accent: mark (U+0301) | plus | strip.
ESPEECH_STRESS_MODE=mark

# Что скармливать модели: plus (по умолчанию — ESpeech ОБУЧЕН на «+»,
# это его родной формат ударений) | mark | strip.
ESPEECH_SYNTH_STRESS=plus

# Обрезка референса, сек (F5 рекомендует < 15).
ESPEECH_REF_MAX_SEC=12

# Биндинг порта: 0.0.0.0 — вся локальная сеть; 127.0.0.1 — только localhost.
ESPEECH_BIND=0.0.0.0

# Предохранитель от гигантских запросов.
MAX_TEXT_CHARS=5000
