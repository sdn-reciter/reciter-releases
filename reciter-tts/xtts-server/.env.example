# Скопируй в .env рядом с docker-compose.yml:  cp .env.example .env
# Значения читаются docker-compose.yml.

# Ключ доступа. Сгенерируй: openssl rand -hex 32
# Приложение шлёт его как  Authorization: Bearer <key>.
# Пусто = без авторизации (ТОЛЬКО для изолированной локальной сети!).
XTTS_API_KEY=

# Голос по умолчанию (имя файла в voices/ без расширения).
# Напр. DEFAULT_SPEAKER=default → voices/default.wav
DEFAULT_SPEAKER=default

# Ударения RUAccent на сервере (нейро-омографы): 1 включает /accent и авто-режим.
USE_RUACCENT=1

# На каком интерфейсе слушать порт 8002:
#   0.0.0.0   — виден в локальной сети (телефон по Wi-Fi достучится). По умолчанию.
#   127.0.0.1 — только localhost (когда сервер стоит за Tailscale).
XTTS_BIND=0.0.0.0

# ── Ударения ────────────────────────────────────────────────────────────────
# Формат ответа /accent для внешних движков (Edge/Google понимают U+0301):
#   mark (по умолчанию) | plus | strip
XTTS_STRESS_MODE=mark
# Что скармливать САМОЙ XTTS при синтезе. ВАЖНО: базовая XTTS-v2 ударения
# НЕ понимает (U+0301 → незнакомые токены → запинки), поэтому по умолчанию
# метки снимаются. plus — только вместе с русским файнтюном (XTTS_MODEL_DIR).
XTTS_SYNTH_STRESS=strip

# ── Кастомная модель (файнтюн с поддержкой ударений) ────────────────────────
# Например xttsv2_banana (huggingface.co/Ftfyhh/xttsv2_banana): скачай
# model.pth, config.json, vocab.json в папку ./model рядом с compose и
# раскомментируй строки ниже.
#XTTS_MODEL_DIR=/app/model
#XTTS_SYNTH_STRESS=plus

# ── Анти-артефакты (дефолты обычно достаточны; см. README.md)
#XTTS_REPETITION_PENALTY=6.0
#XTTS_SENT_PAUSE_MS=250
