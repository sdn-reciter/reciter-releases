# Скопируйте в .env рядом с docker-compose.yml и поправьте под себя.

# Ключ API. Пусто = без авторизации (только для изолированной локальной сети!).
VOXCPM_API_KEY=

# HF id модели.
VOXCPM_MODEL=openbmb/VoxCPM2

# auto: cuda при наличии, иначе CPU. Принудительно: cuda | cpu.
VOXCPM_DEVICE=auto

# Голос по умолчанию — имя .wav из ./voices (без расширения).
# Пусто = встроенный голос модели (генерация без референса).
VOXCPM_DEFAULT_SPEAKER=

# Ударения RUAccent для /accent (серверный режим ударений в приложении).
USE_RUACCENT=1

# Формат ответа /accent: mark (U+0301) | plus | strip.
VOXCPM_STRESS_MODE=mark

# Что скармливать самой модели: strip (по умолчанию) | mark | plus.
# Поддержка меток ударений у VoxCPM не документирована — можно
# поэкспериментировать и сравнить на слух.
VOXCPM_SYNTH_STRESS=strip

# Guidance (сила следования тексту/референсу).
VOXCPM_CFG=2.0

# Шаги диффузии (больше = лучше и медленнее; на CPU можно 6).
VOXCPM_TIMESTEPS=10

# Референс длиннее этого (сек) режется — длинный эталон при VAE-кодировании
# не влезает в VRAM 8-ГБ карты (CUDA OOM). ~10-12 с чистой речи достаточно.
VOXCPM_REF_MAX_SEC=12

# Фиксированный seed: стабильный «встроенный» голос, когда нет референса
# (иначе VoxCPM сэмплирует случайный голос на каждый запрос).
VOXCPM_SEED=42

# Денойзер (для ШУМНЫХ эталонов) и CUDA-графы. По умолчанию 0 — иначе
# VoxCPM2 не влезает в 8 ГБ (RTX 5060). На 12+ ГБ можно 1 для качества.
VOXCPM_DENOISER=0
VOXCPM_OPTIMIZE=0

# Пауза между предложениями в склейке, мс.
VOXCPM_SENT_PAUSE_MS=200

# Абзацы длиннее этого делятся по предложениям.
VOXCPM_CHUNK_CHARS=400

# Биндинг порта: 0.0.0.0 — вся локальная сеть; 127.0.0.1 — только localhost.
VOXCPM_BIND=0.0.0.0

# Предохранитель от гигантских запросов.
MAX_TEXT_CHARS=5000
