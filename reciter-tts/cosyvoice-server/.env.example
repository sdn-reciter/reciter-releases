# Скопируйте в .env рядом с docker-compose.yml и поправьте под себя.

# Ключ API. Пусто = без авторизации (только для изолированной локальной сети!).
COSYVOICE_API_KEY=

# Устройство: auto (GPU при наличии) | cuda | cpu.
COSYVOICE_DEVICE=auto

# Голос по умолчанию: имя wav из ./voices (без расширения). Пусто → первый.
# ВАЖНО: CosyVoice3 клонирует по образцу — каталог voices не может быть пуст.
COSYVOICE_DEFAULT_SPEAKER=

# Ударения RUAccent для /accent (серверный режим ударений в приложении).
USE_RUACCENT=1

# Формат ответа /accent: mark (U+0301) | plus | strip.
COSY_STRESS_MODE=mark

# Что скармливать МОДЕЛИ: strip (по умолчанию — CosyVoice3 метки НЕ читает).
COSY_SYNTH_STRESS=strip

# Обрезка длинного эталона (CosyVoice берёт speech-token только из ≤30 с).
COSY_PROMPT_MAX_SEC=18

# Системный промпт CosyVoice3 (текст ДО <|endofprompt|>, не озвучивается).
# Токен обязателен для CV3; менять обычно не нужно.
COSY_SYS_PROMPT=You are a helpful assistant.

# Биндинг порта: 0.0.0.0 — вся локальная сеть; 127.0.0.1 — только localhost.
COSYVOICE_BIND=0.0.0.0

# Предохранитель от гигантских запросов.
MAX_TEXT_CHARS=5000
