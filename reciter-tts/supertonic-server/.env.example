# Скопируйте в .env рядом с docker-compose.yml и поправьте под себя.

# Ключ API. Пусто = без авторизации (только для изолированной локальной сети!).
SUPERTONIC_API_KEY=

# Голос по умолчанию: пресет (F1–F5, M1–M5) или имя JSON-стиля из ./styles
# (без расширения).
SUPERTONIC_DEFAULT_VOICE=F1

# Ударения RUAccent для /accent (серверный режим ударений в приложении).
USE_RUACCENT=1

# Качество синтеза: 5–12 (больше = лучше и медленнее).
SUPERTONIC_STEPS=8

# Базовая скорость речи модели.
SUPERTONIC_SPEED=1.0

# Формат ответа /accent: mark (U+0301) | plus | strip.
SUPERTONIC_STRESS_MODE=mark

# Что скармливать самой модели: strip (по умолчанию) | mark | plus.
# Поддержка меток ударений у Supertonic не документирована — для
# эксперимента можно попробовать mark/plus и сравнить на слух.
SUPERTONIC_SYNTH_STRESS=strip

# Устройство инференса: auto (GPU, если CUDAExecutionProvider доступен) |
# gpu (принудительно, предупреждает и падает на CPU, если GPU не виден) | cpu.
SUPERTONIC_DEVICE=auto

# Биндинг порта: 0.0.0.0 — вся локальная сеть; 127.0.0.1 — только localhost.
SUPERTONIC_BIND=0.0.0.0

# Предохранитель от гигантских запросов.
MAX_TEXT_CHARS=5000
